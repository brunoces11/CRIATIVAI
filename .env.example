APP_ENV=development
APP_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=
FRONTEND_DIST_DIR=
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
BASE_TIMEZONE=America/Sao_Paulo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MOCK_RESPONSE=
SDR_PROMPT_PATH=backend/app/prompts/sdr_default.md
CHAT_MESSAGE_MAX_CHARS=2000
CHAT_RATE_LIMIT_COUNT=8
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_CONTEXT_RECENT_MESSAGES=12
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/oauth/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_TOKEN_PATH=data/google-token.json
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_OAUTH_SUCCESS_PATH=/adm?google=connected
GOOGLE_OAUTH_ERROR_PATH=/adm?google=error
GOOGLE_OAUTH_SCOPES=["https://www.googleapis.com/auth/calendar.freebusy","https://www.googleapis.com/auth/calendar.events"]
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
SMTP_SENDER_NAME=CriativAI
SMTP_SENDER_EMAIL=
SMTP_REPLY_TO=
