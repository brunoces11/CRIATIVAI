# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.venv
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# build output
/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.codex-dev.*
.codex-dev-*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.exemple

# vercel
.vercel

# generated output
/outputs/
/work/
/data/
__pycache__/
*.pyc
